      "get": {
        "tags": ["Hearings"],
        "summary": "Get all hearings",
        "parameters": [
          { "in": "query", "name": "case_id", "schema": { "type": "string" }, "description": "Filter by case ID", "example": "SLT-001" },
          { "in": "query", "name": "filter", "schema": { "type": "string", "enum": ["upcoming", "this_week"] }, "description": "`upcoming` = future only, `this_week` = next 7 days" }
        ],
        "responses": {
          "200": { "description": "List of hearings" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "tags": ["Hearings"],
        "summary": "Schedule a new hearing",
        "description": "Any authenticated user can schedule a hearing. `created_by` is set automatically from the JWT. Hearing date must be today or in the future.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["case_id", "hearing_date"],
                "properties": {
                  "case_id": { "type": "string", "example": "SLT-001" },
                  "hearing_date": { "type": "string", "format": "date", "example": "2026-04-15", "description": "Must be today or a future date" },
                  "hearing_time": { "type": "string", "example": "09:00" },
                  "court_name": { "type": "string", "example": "High Court Lagos" },
                  "notes": { "type": "string", "example": "Bring certified copies of all exhibits" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Hearing scheduled. A confirmation email is sent automatically.",
            "content": {
              "application/json": {
                "example": { "success": true, "message": "Hearing scheduled successfully", "data": { "id": "770e0400-039d-43f6-9938-668877660099", "case_id": "SLT-001", "hearing_date": "2026-04-15", "urgency": "Green" } }
              }
            }
          },
          "400": { "description": "Past date not allowed or validation error" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
